{
  "name": "sitesawa",
  "version": "2.1.0",
  "description": "Website template store with M-Pesa payments, file-based templates, and Render hosting. Customers bring their own domain.",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy": "./deploy.sh production",
    "deploy:staging": "./deploy.sh staging",
    "test": "echo 'Error: no test specified' && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "ci": "npm ci",
    "update:deps": "npm update",
    "update:check": "npm outdated"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "axios": "^1.7.0",
    "nodemailer": "^6.9.0",
    "helmet": "^7.2.0",
    "express-rate-limit": "^7.5.0",
    "validator": "^13.12.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "eslint": "^8.57.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sitesawa/sitesawa.git"
  },
  "keywords": [
    "website-templates",
    "mpesa",
    "kenya",
    "ecommerce",
    "bootstrap",
    "render"
  ],
  "author": "SiteSawa Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sitesawa/sitesawa/issues"
  },
  "homepage": "https://sitesawa.co.ke"
}
